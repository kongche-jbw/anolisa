#!/usr/bin/env bash
# anolisa-for-openclaw — Unified OpenClaw adapter orchestrator for Anolisa.
#
# Calls per-component OpenClaw adapter scripts via a fixed env contract.
# Does NOT build source, does NOT replicate component-private logic.
#
# Usage:
#   ./scripts/anolisa-for-openclaw --mode recommended
#   ./scripts/anolisa-for-openclaw --component sec-core --component tokenless
#   ./scripts/anolisa-for-openclaw --uninstall --component tokenless
#   ./scripts/anolisa-for-openclaw --status
#   ./scripts/anolisa-for-openclaw --dry-run --mode recommended
#
# Remote (curl | bash) usage:
#   curl -fsSL https://raw.githubusercontent.com/alibaba/anolisa/main/scripts/anolisa-for-openclaw \
#     | bash -s -- --mode recommended
set -euo pipefail

# ─── colors (only when stdout is a TTY) ───
if [[ -t 1 ]]; then
    RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
    BLUE=$'\033[0;34m'; CYAN=$'\033[0;36m'; BOLD=$'\033[1m'
    DIM=$'\033[2m';    NC=$'\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; BLUE=''; CYAN=''; BOLD=''; DIM=''; NC=''
fi

info()  { printf '%s[info]%s  %s\n' "$BLUE"   "$NC" "$*"; }
ok()    { printf '%s[ok]%s    %s\n' "$GREEN"  "$NC" "$*"; }
warn()  { printf '%s[warn]%s  %s\n' "$YELLOW" "$NC" "$*" >&2; }
err()   { printf '%s[error]%s %s\n' "$RED"    "$NC" "$*" >&2; }
step()  { printf '\n%s%s==> %s%s\n' "$CYAN" "$BOLD" "$*" "$NC"; }
die()   { err "$@"; exit 1; }

# ─── defaults ───
ACTION="install"             # install | uninstall
DO_STATUS=false
DRY_RUN=false
MODE=""                       # ""|recommended|all
INSTALL_MODE="user"
OPENCLAW_HOME="${OPENCLAW_HOME:-$HOME/.openclaw}"
PROJECT_ROOT_OVERRIDE=""
COMPONENTS_INPUT=()           # raw user input
PROJECT_ROOT=""               # resolved later
EFFECTIVE_COMPONENTS=()       # resolved component list (after dedupe)

# Adapter discovery output
ADAPTER_ROOT=""
ADAPTER_SCRIPT=""
ADAPTER_TARGET_DIR=""

# ─── component metadata ───
# Stable order for output / dedupe.
KNOWN_COMPONENTS=(os-skills sec-core tokenless ws-ckpt agentsight)

RECOMMENDED_SET=(os-skills sec-core tokenless ws-ckpt)
# 'all' currently resolves to the same set as 'recommended' because the only
# other known component (agentsight) has no OpenClaw adapter. If a future
# component ships an adapter, extend ALL_SET here, not RECOMMENDED_SET.
ALL_SET=("${RECOMMENDED_SET[@]}")

# Components that need OpenClaw gateway restart after install.
GATEWAY_RESTART_COMPONENTS=(sec-core tokenless)

# Skills expected under ~/.openclaw/skills after a recommended install
# (sec-core ships 3, ws-ckpt ships 1). Used by --status presence checks.
KNOWN_SKILLS=(ws-ckpt code-scanner prompt-scanner skill-ledger)

# OpenClaw plugins registered by recommended install (tokenless + sec-core).
KNOWN_PLUGINS=(tokenless-openclaw agent-sec)

# Source-tree fallback path (relative to PROJECT_ROOT).
component_src_subpath() {
    case "$1" in
        os-skills)  echo "src/os-skills/adapters" ;;
        sec-core)   echo "src/agent-sec-core/adapters" ;;
        tokenless)  echo "src/tokenless/adapters/tokenless" ;;
        ws-ckpt)    echo "src/ws-ckpt/adapters" ;;
        agentsight) return 1 ;;
        *)          return 1 ;;
    esac
}

# Components without a real OpenClaw adapter — recognized but skipped.
component_is_unsupported() {
    [[ "$1" == "agentsight" ]]
}

resolve_component_name() {
    case "$1" in
        skills)    echo "os-skills" ;;
        sight)     echo "agentsight" ;;
        os-skills|sec-core|tokenless|ws-ckpt|agentsight) echo "$1" ;;
        *) return 1 ;;
    esac
}

usage() {
    cat <<EOF
${BOLD}anolisa-for-openclaw${NC} — Unified OpenClaw adapter orchestrator

Usage:
  $0 [--mode recommended|all] [--component <name>]... [options]
  $0 --uninstall [--component <name>]... [options]
  $0 --status [options]

Options:
  --mode recommended|all       Component preset (recommended = os-skills,sec-core,tokenless,ws-ckpt)
  --component <name>           Add component (repeatable). Aliases: skills→os-skills, sight→agentsight
  --uninstall                  Run uninstall action instead of install
  --status                     Print runtime/adapter/skill diagnostic and exit
  --dry-run                    Print plan, do not execute adapter scripts
  --openclaw-home <dir>        OpenClaw home (default: \$HOME/.openclaw)
  --project-root <dir>         Anolisa repo root (enables source fallback)
  --install-mode user|system   Install profile (default: user)
  -h, --help                   Show this help

Components: os-skills, sec-core, tokenless, ws-ckpt, agentsight
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --mode)
                [[ -n "${2:-}" ]] || die "--mode requires a value"
                case "$2" in recommended|all) MODE="$2" ;; *) die "invalid --mode: $2" ;; esac
                shift 2 ;;
            --component)
                [[ -n "${2:-}" ]] || die "--component requires a value"
                COMPONENTS_INPUT+=("$2"); shift 2 ;;
            --uninstall)        ACTION="uninstall"; shift ;;
            --status)           DO_STATUS=true; shift ;;
            --dry-run)          DRY_RUN=true; shift ;;
            --openclaw-home)
                [[ -n "${2:-}" ]] || die "--openclaw-home requires a value"
                OPENCLAW_HOME="$2"; shift 2 ;;
            --project-root)
                [[ -n "${2:-}" ]] || die "--project-root requires a value"
                PROJECT_ROOT_OVERRIDE="$2"; shift 2 ;;
            --install-mode)
                [[ -n "${2:-}" ]] || die "--install-mode requires a value"
                case "$2" in user|system) INSTALL_MODE="$2" ;; *) die "invalid --install-mode: $2" ;; esac
                shift 2 ;;
            -h|--help)          usage; exit 0 ;;
            *)                  die "unknown option: $1 (see --help)" ;;
        esac
    done
}

# Detect a usable PROJECT_ROOT for source-tree fallback. Three tiers:
#   1. --project-root override
#   2. Script lives inside a checkout (BASH_SOURCE traceable, ../src/agent-sec-core/openclaw-plugin exists)
#   3. Empty (curl|bash mode) — only installed paths will be scanned
resolve_project_root() {
    if [[ -n "$PROJECT_ROOT_OVERRIDE" ]]; then
        [[ -d "$PROJECT_ROOT_OVERRIDE" ]] || die "--project-root not a directory: $PROJECT_ROOT_OVERRIDE"
        PROJECT_ROOT="$(cd "$PROJECT_ROOT_OVERRIDE" && pwd)"
        return 0
    fi

    local src="${BASH_SOURCE[0]:-}"
    if [[ -n "$src" && "$src" != /tmp/* && "$src" != /dev/fd/* ]]; then
        local script_dir maybe_root
        script_dir="$(cd "$(dirname "$src")" 2>/dev/null && pwd -P)" || true
        if [[ -n "$script_dir" ]]; then
            maybe_root="$(cd "$script_dir/.." 2>/dev/null && pwd -P)" || true
            # Repo-level sentinels: build-all.sh sibling + src/ tree.
            # Avoids coupling to any one component's path.
            if [[ -n "$maybe_root" \
               && -f "$maybe_root/scripts/build-all.sh" \
               && -d "$maybe_root/src" ]]; then
                PROJECT_ROOT="$maybe_root"
                return 0
            fi
        fi
    fi

    PROJECT_ROOT=""
}

# Build effective component list = MODE preset ∪ explicit, deduped, in KNOWN_COMPONENTS order.
build_component_list() {
    local selected=() seen="" raw resolved c x
    if [[ -n "$MODE" ]]; then
        case "$MODE" in
            recommended) selected=("${RECOMMENDED_SET[@]}") ;;
            all)         selected=("${ALL_SET[@]}") ;;
        esac
    fi
    for raw in "${COMPONENTS_INPUT[@]+"${COMPONENTS_INPUT[@]}"}"; do
        resolved="$(resolve_component_name "$raw")" || die "unknown component: $raw"
        selected+=("$resolved")
    done
    if [[ ${#selected[@]} -eq 0 ]]; then
        die "no components selected (use --mode or --component)"
    fi
    # Dedupe in KNOWN_COMPONENTS order.
    EFFECTIVE_COMPONENTS=()
    for c in "${KNOWN_COMPONENTS[@]}"; do
        for x in "${selected[@]}"; do
            if [[ "$x" == "$c" ]] && [[ ",$seen," != *",$c,"* ]]; then
                EFFECTIVE_COMPONENTS+=("$c")
                seen="$seen,$c"
                break
            fi
        done
    done
}

# Resolve the adapter root for $component+$action by checking candidates in order.
# Sets ADAPTER_ROOT, ADAPTER_TARGET_DIR (may be empty), ADAPTER_SCRIPT.
# Returns 0 if found, 1 otherwise.
find_openclaw_adapter() {
    local component="$1" action="$2"
    local script_rel="openclaw/scripts/${action}.sh"
    local candidates=()

    if [[ -n "$PROJECT_ROOT" ]]; then
        candidates+=("$PROJECT_ROOT/target/${component}/share/anolisa/adapters/${component}")
    fi
    candidates+=("$HOME/.local/share/anolisa/adapters/${component}")
    candidates+=("/usr/share/anolisa/adapters/${component}")
    if [[ -n "$PROJECT_ROOT" ]]; then
        local sub
        if sub="$(component_src_subpath "$component")"; then
            candidates+=("$PROJECT_ROOT/$sub")
        fi
    fi

    local cand
    for cand in "${candidates[@]}"; do
        if [[ -f "$cand/$script_rel" ]]; then
            ADAPTER_ROOT="$cand"
            ADAPTER_SCRIPT="$cand/$script_rel"
            if [[ -n "$PROJECT_ROOT" && -d "$PROJECT_ROOT/target/$component" ]]; then
                ADAPTER_TARGET_DIR="$PROJECT_ROOT/target/$component"
            else
                ADAPTER_TARGET_DIR=""
            fi
            return 0
        fi
    done

    ADAPTER_ROOT=""
    ADAPTER_SCRIPT=""
    ADAPTER_TARGET_DIR=""
    return 1
}

# sec-core paths derived from install mode.
sec_core_plugin_dir() {
    if [[ "$INSTALL_MODE" == "system" ]]; then
        echo "/usr/lib/anolisa/sec-core/openclaw-plugin"
    else
        echo "$HOME/.local/lib/anolisa/sec-core/openclaw-plugin"
    fi
}

sec_core_bin_dir() {
    if [[ "$INSTALL_MODE" == "system" ]]; then
        echo "/usr/local/bin"
    else
        echo "$HOME/.local/bin"
    fi
}

run_adapter() {
    local component="$1" action="$2"
    local dry_int=0
    $DRY_RUN && dry_int=1

    if ! find_openclaw_adapter "$component" "$action"; then
        die "${component}: OpenClaw adapter ${action}.sh not found (looked in target/, ~/.local/, /usr/share/, src/)"
    fi

    if $DRY_RUN; then
        echo "[plan] component=${component}"
        echo "[plan]   adapter=${ADAPTER_ROOT}"
        echo "[plan]   target=${ADAPTER_TARGET_DIR:-<empty>}"
        echo "[plan]   action=${action}"
        echo "[plan]   command: bash ${ADAPTER_SCRIPT}"
        return 0
    fi

    step "${component} → OpenClaw (${action})"
    env \
        ANOLISA_COMPONENT="$component" \
        ANOLISA_TARGET="openclaw" \
        ANOLISA_ADAPTER_DIR="$ADAPTER_ROOT" \
        ANOLISA_TARGET_DIR="${ADAPTER_TARGET_DIR}" \
        ANOLISA_PROJECT_ROOT="${PROJECT_ROOT}" \
        ANOLISA_INSTALL_MODE="$INSTALL_MODE" \
        ANOLISA_DRY_RUN="$dry_int" \
        OPENCLAW_HOME="$OPENCLAW_HOME" \
        OPENCLAW_SKILLS_DIR="$OPENCLAW_HOME/skills" \
        SEC_CORE_OPENCLAW_PLUGIN_DIR="$(sec_core_plugin_dir)" \
        SEC_CORE_BIN_DIR="$(sec_core_bin_dir)" \
        bash "$ADAPTER_SCRIPT"
}

cmd_dispatch() {
    build_component_list

    if $DRY_RUN; then
        echo "[plan] action=${ACTION} mode=${MODE:-<explicit>} install-mode=${INSTALL_MODE}"
        echo "[plan] openclaw-home=${OPENCLAW_HOME}"
        echo "[plan] project-root=${PROJECT_ROOT:-<empty>}"
    fi

    local restart_needed=false c r
    for c in "${EFFECTIVE_COMPONENTS[@]}"; do
        if component_is_unsupported "$c"; then
            warn "${c}: no OpenClaw adapter expected; skipping"
            continue
        fi
        run_adapter "$c" "$ACTION"
        if [[ "$ACTION" == "install" ]]; then
            for r in "${GATEWAY_RESTART_COMPONENTS[@]}"; do
                [[ "$r" == "$c" ]] && restart_needed=true
            done
        fi
    done

    if $restart_needed && ! $DRY_RUN; then
        echo ""
        printf '%s[hint]%s run %sopenclaw gateway restart%s to activate the new plugins.\n' \
            "$YELLOW" "$NC" "$BOLD" "$NC"
    fi
}

cmd_status() {
    step "OpenClaw runtime"
    if command -v openclaw >/dev/null 2>&1; then
        echo "  openclaw CLI:    found ($(command -v openclaw))"
    else
        echo "  openclaw CLI:    missing"
    fi
    if [[ -d "$OPENCLAW_HOME" ]]; then
        echo "  OpenClaw home:   $OPENCLAW_HOME (exists)"
    else
        echo "  OpenClaw home:   $OPENCLAW_HOME (missing)"
    fi

    step "Adapters"
    local c install_state uninstall_state src_path
    for c in "${KNOWN_COMPONENTS[@]}"; do
        if component_is_unsupported "$c"; then
            printf "  %-12s unsupported (no OpenClaw adapter)\n" "$c"
            continue
        fi
        if find_openclaw_adapter "$c" "install"; then
            install_state="found"
            src_path="$ADAPTER_ROOT"
        else
            install_state="missing"
            src_path="-"
        fi
        if find_openclaw_adapter "$c" "uninstall"; then
            uninstall_state="found"
        else
            uninstall_state="missing"
        fi
        printf "  %-12s install=%s uninstall=%s source=%s\n" \
            "$c" "$install_state" "$uninstall_state" "$src_path"
    done

    step "OpenClaw skills (${OPENCLAW_HOME%/}/skills)"
    local skill
    for skill in "${KNOWN_SKILLS[@]}"; do
        if [[ -f "${OPENCLAW_HOME%/}/skills/$skill/SKILL.md" ]]; then
            printf "  %-24s present\n" "$skill/SKILL.md"
        else
            printf "  %-24s missing\n" "$skill/SKILL.md"
        fi
    done

    step "OpenClaw plugins"
    if command -v openclaw >/dev/null 2>&1; then
        local plugins plugins_json p
        plugins_json="$(openclaw plugins list --json 2>/dev/null || true)"
        plugins="$(openclaw plugins list 2>/dev/null || true)"
        for p in "${KNOWN_PLUGINS[@]}"; do
            if grep -qE "\"id\"[[:space:]]*:[[:space:]]*\"${p}\"" <<<"$plugins_json"; then
                printf "  %-24s listed\n" "$p"
            # Fallback for older OpenClaw versions without --json.
            elif grep -qE "(^|[[:space:]])${p}([[:space:]]|$)" <<<"$plugins"; then
                printf "  %-24s listed\n" "$p"
            else
                printf "  %-24s not listed\n" "$p"
            fi
        done
    else
        echo "  N/A (openclaw CLI missing)"
    fi
}

main() {
    parse_args "$@"
    resolve_project_root
    if $DO_STATUS; then
        cmd_status
        exit 0
    fi
    cmd_dispatch
}

main "$@"
